{
  "name": "overleaf-folder-sync",
  "version": "0.1.1",
  "description": "A folder-oriented Overleaf sync CLI using an overleaf_session2 cookie.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/Guosen-Wu/overleaf-folder-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guosen-Wu/overleaf-folder-sync.git"
  },
  "bugs": {
    "url": "https://github.com/Guosen-Wu/overleaf-folder-sync/issues"
  },
  "keywords": [
    "overleaf",
    "latex",
    "sync",
    "cli"
  ],
  "files": [
    "dist/auth",
    "dist/compile",
    "dist/config",
    "dist/overleaf",
    "dist/sync",
    "dist/util",
    "dist/cli.d.ts",
    "dist/cli.js",
    "README.md",
    "EN_README.md",
    "LICENSE"
  ],
  "bin": {
    "olfs": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
